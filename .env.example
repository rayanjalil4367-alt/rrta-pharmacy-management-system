# Copy this file to .env and fill in your real values.
# .env is gitignored and should NEVER be committed.

# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=pharmacymanagementsystem

# Flask
SECRET_KEY=generate_a_random_secret_key_here
FLASK_DEBUG=True
FLASK_PORT=5000

# Admin login passwords
RAYAN_PASSWORD=choose_a_password
TAHA_PASSWORD=choose_a_password
ALI_PASSWORD=choose_a_password
RAFAY_PASSWORD=choose_a_password
